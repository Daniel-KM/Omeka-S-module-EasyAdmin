<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\AbstractResourceEntityRepresentation $resource
 * @var \Omeka\Api\Representation\AbstractResourceEntityRepresentation $previous
 * @var \Omeka\Api\Representation\AbstractResourceEntityRepresentation $next
 * @var bool $back
 * @var string $lastBrowseUrl
 * @var array $options Passed options.
 */

$plugins = $this->getHelperPluginManager();
$translate = $plugins->get('translate');
$hyperlink = $plugins->get('hyperlink');
$escapeAttr = $plugins->get('escapeHtmlAttr');

$disabledLink = function (string $label, string $title) use ($escapeAttr): string {
    return sprintf(
        '<span class="button button-disabled" role="link" aria-disabled="true" aria-label="%1$s" title="%1$s">%2$s</span>',
        $escapeAttr($title),
        $escapeAttr($label)
    );
};

if ($previous):
    echo $hyperlink('<', $previous->url('show'), ['class' => 'button', 'rel' => 'prev', 'title' => $translate('Previous resource'), 'aria-label' => $translate('Previous resource')]);
else:
    echo $disabledLink('<', $translate('No previous resource'));
endif;

if (!empty($back)):
    if ($lastBrowseUrl):
        echo $hyperlink('^', $lastBrowseUrl, ['class' => 'button', 'rel' => 'search', 'title' => $translate('Back to last search'), 'aria-label' => $translate('Back to last search')]);
    else:
        echo $disabledLink('^', $translate('Back to last search'));
    endif;
endif;

if ($next):
    echo $hyperlink('>', $next->url('show'), ['class' => 'button', 'rel' => 'next', 'title' => $translate('Next resource'), 'aria-label' => $translate('Next resource')]);
else:
    echo $disabledLink('>', $translate('No next resource'));
endif;
