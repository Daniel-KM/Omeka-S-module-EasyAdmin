<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var string $themeId
 * @var array $ini
 * @var array|null $addon
 * @var array|null $integrity
 * @var array $themeSites
 */

$plugins = $this->getHelperPluginManager();
$escape = $plugins->get('escapeHtml');
$translate = $plugins->get('translate');

$name = $ini['name'] ?? $themeId;
$composerAddonsPath = OMEKA_PATH . '/composer-addons/themes';
$isComposer = is_dir($composerAddonsPath . '/' . $themeId);

$themesDir = OMEKA_PATH . '/themes';
$thumbFile = $themesDir . '/' . $themeId . '/theme.jpg';
$thumbUrl = null;
if (file_exists($thumbFile)) {
    $thumbUrl = $this->basePath('themes/' . $themeId . '/theme.jpg');
}
?>

<h3><?= $escape($name) ?></h3>

<?php if ($thumbUrl): ?>
<div class="theme-thumbnail">
    <img src="<?= $escape($thumbUrl) ?>" alt="<?= $escape($name) ?>" class="theme-thumb">
</div>
<?php endif ?>

<?php if (!empty($ini['version'])): ?>
<div class="meta-group">
    <h4><?= $translate('Installed version') ?></h4>
    <div class="value"><?= $escape($ini['version']) ?></div>
</div>
<?php endif ?>

<?php if ($themeSites): ?>
<div class="meta-group item-sites">
    <h4><?= $translate('Sites') ?></h4>
    <?php
    $url = $plugins->get('url');
    $hyperlink = $plugins->get('hyperlink');
    foreach ($themeSites as $site): ?>
    <div class="value">
        <a href="<?= $escape($url('admin/site/slug', ['site-slug' => $site['slug']])) ?>"><?= $escape($site['title']) ?></a>
        <?= $hyperlink('', $url('site', ['site-slug' => $site['slug']]), [
            'class' => 'o-icon-external',
            'target' => '_blank',
            'rel' => 'noopener noreferrer',
            'title' => $site['title'],
            'aria-label' => sprintf($translate('Open %s in a new tab'), $site['title']),
        ]) ?>
    </div>
    <?php endforeach ?>
</div>
<?php endif ?>

<?php if (!empty($ini['author'])): ?>
<div class="meta-group">
    <h4><?= $translate('Author') ?></h4>
    <div class="value"><?= $escape($ini['author']) ?></div>
</div>
<?php endif ?>

<?php if (!empty($ini['description'])): ?>
<div class="meta-group">
    <h4><?= $translate('Description') ?></h4>
    <div class="value"><?= $escape($ini['description']) ?></div>
</div>
<?php endif ?>

<?php if (!empty($ini['theme_link'])): ?>
<div class="meta-group">
    <h4><?= $translate('Link') ?></h4>
    <div class="value"><a href="<?= $escape($ini['theme_link']) ?>" target="_blank" rel="noopener noreferrer"><?= $escape($ini['theme_link']) ?></a></div>
</div>
<?php endif ?>

<?php
$omekaOrgUrl = ($addon['server'] ?? '') === 'omeka.org'
    ? 'https://omeka.org/s/themes/' . ($addon['dir'] ?? '')
    : null;
if ($omekaOrgUrl): ?>
<div class="meta-group">
    <h4><?= $translate('Omeka.org') ?></h4>
    <div class="value"><a href="<?= $escape($omekaOrgUrl) ?>" target="_blank" rel="noopener noreferrer" class="o-icon-omeka" title="<?= $escape($translate('View on Omeka.org')) ?>"><?= $escape($translate('View on Omeka.org')) ?></a></div>
</div>
<?php endif ?>

<?php if (!empty($ini['omeka_version_constraint'])): ?>
<div class="meta-group">
    <h4><?= $translate('Omeka S version required') ?></h4>
    <div class="value"><?= $escape($ini['omeka_version_constraint']) ?></div>
</div>
<?php endif ?>

<div class="meta-group">
    <h4><?= $translate('Source') ?></h4>
    <div class="value"><?= $isComposer ? 'Composer' : $translate('Local') ?></div>
</div>

<?php if ($addon && !empty($addon['version'])): ?>
<div class="meta-group">
    <h4><?= $translate('Catalogue version') ?></h4>
    <div class="value"><?= $escape($addon['version']) ?></div>
</div>
<?php endif ?>

<?php if ($addon && !empty($addon['dependencies'])): ?>
<div class="meta-group">
    <h4><?= $translate('Dependencies') ?></h4>
    <div class="value"><?= $escape(implode(', ', $addon['dependencies'])) ?></div>
</div>
<?php endif ?>

<?php if ($integrity): ?>
<div class="meta-group">
    <h4><?= $translate('Integrity') ?></h4>
    <?php if ($integrity['status'] === 'clean'): ?>
    <div class="value success"><?= $translate('All files match the reference checksums.') ?></div>
    <?php elseif ($integrity['status'] === 'modified'): ?>
    <div class="value error"><?= $translate('Some files have been modified.') ?></div>
    <?php if (!empty($integrity['modified'])): ?>
    <h4><?= $translate('Modified') ?></h4>
    <ul>
        <?php foreach ($integrity['modified'] as $file): ?>
        <li><?= $escape($file) ?></li>
        <?php endforeach ?>
    </ul>
    <?php endif ?>
    <?php if (!empty($integrity['added'])): ?>
    <h4><?= $translate('Added') ?></h4>
    <ul>
        <?php foreach ($integrity['added'] as $file): ?>
        <li><?= $escape($file) ?></li>
        <?php endforeach ?>
    </ul>
    <?php endif ?>
    <?php if (!empty($integrity['deleted'])): ?>
    <h4><?= $translate('Deleted') ?></h4>
    <ul>
        <?php foreach ($integrity['deleted'] as $file): ?>
        <li><?= $escape($file) ?></li>
        <?php endforeach ?>
    </ul>
    <?php endif ?>
    <?php else: ?>
    <div class="value"><?= $translate('No reference checksums available.') ?></div>
    <?php endif ?>
</div>
<?php endif ?>
