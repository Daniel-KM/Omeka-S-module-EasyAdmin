<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var array $omekaThemes
 * @var array $webThemes
 * @var array $localThemes
 * @var array $sitesByTheme
 * @var string|null $filterState
 * @var \EasyAdmin\Form\AddonManageForm $manageForm
 * @var callable $stateForm
 * @var \EasyAdmin\Form\ModuleStateForm $installCatalogueForm
 */

$plugins = $this->getHelperPluginManager();
$url = $plugins->get('url');
$escape = $plugins->get('escapeHtml');
$assetUrl = $plugins->get('assetUrl');
$translate = $plugins->get('translate');
$hyperlink = $plugins->get('hyperlink');

$this->headLink()
    ->appendStylesheet($assetUrl('css/easy-admin.css', 'EasyAdmin'));
$this->htmlElement('body')->appendAttribute('class', 'themes browse easy-admin');

$composerAddonsPath = OMEKA_PATH . '/composer-addons/themes';
$omekaVersion = \Omeka\Module::VERSION;

// Merged catalogue for update detection.
$catalogueThemes = array_merge($omekaThemes, $webThemes);
?>

<?= $this->pageTitle($translate('Manage themes'), 1, $translate('Easy Admin')) ?>

<nav class="section-nav">
    <?= $this->navigation('Laminas\Navigation\EasyAdmin')->menu() ?>
</nav>

<?php if (!$catalogueThemes): ?>
<div class="messages warning">
    <p><?= $escape($translate('The theme catalogue could not be loaded. Update detection is unavailable. Check the server internet access or refresh the catalogue.')) ?></p>
</div>
<?php endif ?>

<?php if (!is_writeable(OMEKA_PATH . '/themes')): ?>
<div class="messages error">
    <p><?= $escape(sprintf($translate('The directory "%s" is not writeable. Theme installation, update and removal are disabled.'), 'themes/')) ?></p>
</div>
<?php endif ?>

<div id="page-actions">
    <button type="button" class="button sidebar-content" data-sidebar-selector="#sidebar-install"><?= $escape($translate('Install new theme')) ?></button>
</div>

<br/>

<?php if ($localThemes): ?>

<?php
$manageForm
    ->prepare()
    ->setAttribute('action', $url('admin/easy-admin/default', ['controller' => 'theme']))
    ->setAttribute('method', 'post')
    ->setAttribute('id', 'batch-form')
    ->setAttribute('class', 'disable-unsaved-warning');
echo $this->form()->openTag($manageForm);
?>

<div class="batch-inputs">
    <select class="batch-actions-select" name="bulk_action" aria-label="<?= $translate('Batch actions') ?>">
        <option value="default"><?= $translate('Batch actions') ?></option>
        <option value="update" disabled="disabled"><?= $escape($translate('Update selected')) ?></option>
        <option value="remove" disabled="disabled"><?= $escape($translate('Remove selected')) ?></option>
    </select>
    <div class="batch-actions">
        <button type="button" class="default active" disabled="disabled"><?= $translate('Go') ?></button>
        <button type="submit" class="update" name="batch_submit" value="update" style="display:none"><?= $translate('Go') ?></button>
        <button type="button" class="delete button sidebar-content remove" data-sidebar-selector="#sidebar-remove-selected" style="display:none"><?= $translate('Go') ?></button>
    </div>
</div>

<table class="tablesaw batch-edit" data-tablesaw-mode="stack">
    <thead>
        <tr>
            <th>
                <input type="checkbox" class="select-all" aria-label="<?= $translate('Select all') ?>">
                <?= $translate('Theme') ?>
            </th>
            <th><?= $translate('Version') ?></th>
            <th><?= $translate('Image') ?></th>
        </tr>
    </thead>
    <tbody>
    <?php foreach ($localThemes as $themeId => $theme):
        $isComposer = is_dir($composerAddonsPath . '/' . $themeId);

        $catalogueVersion = null;
        foreach ($catalogueThemes as $ct) {
            if (strcasecmp($ct['dir'] ?? '', $themeId) === 0) {
                $catalogueVersion = $ct['version'] ?? null;
                break;
            }
        }
        $hasUpdate = $catalogueVersion
            && $theme['version']
            && version_compare($theme['version'], $catalogueVersion, '<');

        $constraint = $theme['omeka_version_constraint'] ?? '';
        $invalidOmeka = $constraint
            && !\Composer\Semver\Semver::satisfies($omekaVersion, $constraint);

        $themePath = $theme['path'] ?? (OMEKA_PATH . '/themes/' . $themeId);
        $thumbFile = $themePath . '/theme.jpg';
        // Derive the web-relative path from the filesystem path.
        $thumbUrl = file_exists($thumbFile)
            ? $this->basePath(substr($themePath, strlen(OMEKA_PATH) + 1) . '/theme.jpg')
            : null;
    ?>
        <tr>
            <td>
                <?php if (!$isComposer): ?>
                <input type="checkbox" name="themes[]" value="<?= $escape($themeId) ?>" aria-label="<?= $escape(sprintf($translate('Select %s'), $theme['name'])) ?>">
                <?php else: ?>
                <span class="checkbox-placeholder"></span>
                <?php endif ?>

                <?php if (!empty($theme['theme_link'])): ?>
                <?= $hyperlink($theme['name'], $theme['theme_link'], ['target' => '_blank', 'rel' => 'noopener noreferrer']) ?>
                <?php else: ?>
                <strong><?= $escape($theme['name']) ?></strong>
                <?php endif ?>
                <?php if ($themeId !== strtolower($theme['name'] ?? '')
                    && $themeId !== str_replace(' ', '', strtolower($theme['name'] ?? ''))
                ): ?>
                <span class="addon-dir">[<?= $escape($themeId) ?>]</span>
                <?php endif ?>

                <?php if (!empty($theme['author'])): ?>
                <span class="addon-author"> — <?= $escape($theme['author']) ?></span>
                <?php endif ?>
                <?php if (!empty($theme['description'])): ?>
                <span class="addon-description"><?= $escape($theme['description']) ?></span>
                <?php endif ?>

                <?php
                $themeSites = $sitesByTheme[$themeId] ?? [];
                if ($themeSites): ?>
                <span class="theme-sites-badge" title="<?= $escape(implode(', ', array_column($themeSites, 'title'))) ?>"><?= count($themeSites) ?></span>
                <?php endif ?>

                <ul class="actions">
                    <?php if (!$isComposer): ?>
                        <?php if ($hasUpdate): ?>
                        <li><?= $hyperlink('', '#', [
                            'data-sidebar-selector' => '#sidebar',
                            'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'theme', 'action' => 'update-confirm'], ['query' => ['id' => $themeId]]),
                            'class' => 'o-icon-install sidebar-content',
                            'title' => $translate('Update files'),
                            'aria-label' => $translate('Update files'),
                        ]) ?></li>
                        <?php endif ?>

                        <li><?= $hyperlink('', '#', [
                            'data-sidebar-selector' => '#sidebar',
                            'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'theme', 'action' => 'remove-confirm'], ['query' => ['id' => $themeId]]),
                            'class' => 'o-icon-delete sidebar-content',
                            'title' => $translate('Remove'),
                            'aria-label' => $translate('Remove'),
                        ]) ?></li>
                    <?php endif ?>

                    <?php if ($isComposer): ?>
                    <li><span class="o-icon-lock" role="img" aria-label="Composer" title="<?= $escape($translate('Managed by Composer')) ?>"></span></li>
                    <?php endif ?>

                    <li><?= $hyperlink('', '#', [
                        'data-sidebar-selector' => '#sidebar',
                        'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'theme', 'action' => 'show-details'], ['query' => ['id' => $themeId]]),
                        'class' => 'o-icon-more sidebar-content',
                        'title' => $translate('Details'),
                        'aria-label' => $translate('Details'),
                    ]) ?></li>
                </ul>
            </td>
            <td class="col-version<?= $hasUpdate ? ' has-update' : '' ?><?= $invalidOmeka ? ' invalid-omeka' : '' ?>">
                <span class="version-current"><?= $escape($theme['version']) ?></span>
                <?php if ($hasUpdate): ?>
                <span class="version-available"><?= sprintf($translate('→ %s'), $escape($catalogueVersion)) ?></span>
                <?php endif ?>
                <?php if ($invalidOmeka): ?>
                <span class="error"><?= sprintf($translate('Requires Omeka S %s'), $escape($constraint)) ?></span>
                <?php endif ?>
            </td>
            <td class="col-image">
                <?php if ($thumbUrl): ?>
                <img src="<?= $escape($thumbUrl) ?>" alt="" class="theme-thumb">
                <?php endif ?>
            </td>
        </tr>
    <?php endforeach ?>
    </tbody>
</table>

<?= $this->form()->closeTag($manageForm) ?>

<div id="sidebar" class="sidebar">
    <?= $hyperlink('', '#', [
        'class' => 'sidebar-close o-icon-close',
        'title' => $translate('Close'),
        'aria-label' => $translate('Close'),
    ]) ?>
    <div class="sidebar-content"></div>
</div>

<?php else: ?>
<div class="no-resources">
    <p><?= $translate('No themes found.') ?></p>
</div>
<?php endif ?>

<?php
// Build a combined list: url => [name, dir, version, installed, isOmeka].
$catalogueList = [];
foreach ($omekaThemes as $catUrl => $t) {
    $catalogueList[$catUrl] = $t + ['is_omeka' => true];
}
foreach ($webThemes as $catUrl => $t) {
    if (!isset($catalogueList[$catUrl])) {
        $catalogueList[$catUrl] = $t + ['is_omeka' => false];
    }
}
uasort($catalogueList, function ($a, $b) {
    return strcasecmp($a['name'], $b['name']);
});
?>

<div id="sidebar-install" class="sidebar">
    <?= $hyperlink('', '#', [
        'class' => 'sidebar-close o-icon-close',
        'title' => $translate('Close'),
        'aria-label' => $translate('Close'),
    ]) ?>
    <div class="sidebar-content">
        <h3><?= $escape($translate('Install new theme from catalogue')) ?></h3>
        <p class="explanation">
            <?= $escape($translate('Select the themes to install.')) ?>
            <?= sprintf($translate('For more information, see pages of known %1$sthemes%2$s or %3$sOmeka.org%2$s.'),
                '<a href="https://daniel-km.github.io/UpgradeToOmekaS/omeka_s_themes.html" rel="noopener" target="_blank">', '</a>',
                '<a href="https://omeka.org/s/themes/" rel="noopener" target="_blank">') ?>
        </p>
        <?php
        $installCatalogueForm->prepare();
        echo $this->form()->openTag($installCatalogueForm);
        ?>
        <div class="addon-checklist">
            <?php foreach ($catalogueList as $catUrl => $catTheme):
                if (!empty($catTheme['installed'])) {
                    continue;
                }
                $sourceUrl = $catTheme['url'] ?? '';
            ?>
            <label class="addon-check-item">
                <input type="checkbox" name="theme_urls[]" value="<?= $escape($catUrl) ?>">
                <span class="addon-check-name"><?= $escape($catTheme['name']) ?></span>
                <span class="addon-check-source">
                <?php if (!empty($catTheme['is_omeka'])): ?>
                    <a href="<?= $escape('https://omeka.org/s/themes/' . ($catTheme['dir'] ?? '')) ?>" target="_blank" rel="noopener noreferrer" class="o-icon-omeka" title="Omeka.org" aria-label="Omeka.org" onclick="event.stopPropagation();"></a>
                <?php elseif ($sourceUrl): ?>
                    <a href="<?= $escape($sourceUrl) ?>" target="_blank" rel="noopener noreferrer" class="o-icon-external" title="<?= $escape($translate('Source')) ?>" aria-label="<?= $escape($translate('Source')) ?>" onclick="event.stopPropagation();"></a>
                <?php endif ?>
                </span>
            </label>
            <?php endforeach ?>
        </div>
        <div class="confirm-panel">
            <button type="submit"><?= $escape($translate('Install selected')) ?></button>
        </div>
        <?= $this->form()->closeTag($installCatalogueForm) ?>
    </div>
</div>
