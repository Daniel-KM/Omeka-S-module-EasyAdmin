// Fallback for non-semver constraints used by some modules (e.g. "1.0-2.0",
// ">= 4.0", "4.0,<5", "4.0||5.0"). Returns null on parse failure.
$checkConstraintFallback = function (string $version, string $constraint): ?bool {
    $constraint = trim($constraint);
    if ($constraint === '' || $constraint === '*') {
        return true;
    }
    // OR split.
    foreach (preg_split('~\s*\|\|\s*~', $constraint) as $orPart) {
        $orPart = trim($orPart);
        if ($orPart === '') {
            continue;
        }
        // Range "A - B" or "A-B" (no operator on either side).
        if (preg_match('~^(?<a>\d[\d.]*)\s*-\s*(?<b>\d[\d.]*)$~', $orPart, $m)) {
            if (version_compare($version, $m['a'], '>=') && version_compare($version, $m['b'], '<=')) {
                return true;
            }
            continue;
        }
        // AND clauses split by comma or whitespace.
        $clauses = preg_split('~[\s,]+~', $orPart);
        $allOk = true;
        foreach ($clauses as $clause) {
            if ($clause === '') {
                continue;
            }
            if (!preg_match('~^(?<op>>=|<=|<>|!=|==|=|>|<|\^|~)?\s*(?<v>\d[\d.A-Za-z\-+]*)$~', $clause, $m)) {
                return null;
            }
            $op = $m['op'] ?: '=';
            $v = $m['v'];
            if ($op === '^' || $op === '~') {
                // Treat ^X.Y / ~X.Y as >=X.Y and <(major+1) for ^, <(minor+1)
                // for ~.
                $parts = explode('.', $v);
                $major = (int) ($parts[0] ?? 0);
                $minor = (int) ($parts[1] ?? 0);
                $upper = $op === '^' ? ($major + 1) . '.0.0' : $major . '.' . ($minor + 1) . '.0';
                if (!version_compare($version, $v, '>=') || !version_compare($version, $upper, '<')) {
                    $allOk = false;
                    break;
                }
                continue;
            }
            $cmpOp = $op === '=' ? '==' : $op;
            if (!version_compare($version, $v, $cmpOp)) {
                $allOk = false;
                break;
            }
        }
        if ($allOk) {
            return true;
        }
    }
    return false;
};

