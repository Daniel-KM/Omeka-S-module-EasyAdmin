                            <button type="submit" name="state_action_id" value="deactivate:<?= $escape($moduleId) ?>"
                                formaction="<?= $escape($url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'deactivate'], ['query' => ['id' => $moduleId]])) ?>"
                                class="o-icon-deactivate button"><?= $translate('Deactivate') ?></button>
                        </li>
                        <?php endif ?>

                        <?php if (Manager::STATE_NEEDS_UPGRADE === $state): ?>
                        <li>
                            <button type="submit" name="state_action_id" value="upgrade:<?= $escape($moduleId) ?>"
                                formaction="<?= $escape($url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'upgrade'], ['query' => ['id' => $moduleId]])) ?>"
                                class="o-icon-upgrade button"><?= $translate('Upgrade') ?></button>
                        </li>
                        <?php endif ?>

                        <?php if ($hasUpdate): ?>
                        <li><?= $hyperlink('', '#', [
                            'data-sidebar-selector' => '#sidebar',
                            'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'update-confirm'], ['query' => ['id' => $moduleId]]),
                            'class' => 'o-icon-upgrade sidebar-content',
                            'title' => $translate('Update files'),
                        ]) ?></li>
                        <?php endif ?>

                        <?php if (in_array($state, [
                            Manager::STATE_ACTIVE,
                            Manager::STATE_NOT_ACTIVE,
                            Manager::STATE_NOT_INSTALLED,
                            Manager::STATE_INVALID_MODULE,
                            Manager::STATE_INVALID_INI,
                            Manager::STATE_INVALID_OMEKA_VERSION,
                        ])): ?>
                        <li><?= $hyperlink('', '#', [
                            'data-sidebar-selector' => '#sidebar',
                            'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'remove-confirm'], ['query' => ['id' => $moduleId]]),
                            'class' => 'o-icon-delete sidebar-content',
                            'title' => $translate('Remove'),
                        ]) ?></li>
                        <?php endif ?>

                    <?php endif ?>

                    <?php if ($isComposer): ?>
                    <li><span class="o-icon-lock" aria-label="Composer" title="<?= $escape($translate('Managed by Composer')) ?>"></span></li>
                    <?php endif ?>

                    <li><?= $hyperlink('', '#', [
                        'data-sidebar-selector' => '#sidebar',
                        'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'show-details'], ['query' => ['id' => $moduleId]]),
                        'class' => 'o-icon-more sidebar-content',
                        'title' => $translate('Details'),
                    ]) ?></li>
                </ul>
            </td>
            <td class="col-version<?= $hasUpdate ? ' has-update' : '' ?><?= $versionMismatch ? ' version-mismatch' : '' ?>">
                <span class="current-version"><?= $escape($version) ?></span>
                <?php if ($versionMismatch): ?>
                <span class="error version-rollback" title="<?= $escapeAttr(sprintf(
                    $translate('The database is on version %1$s but the installed files are on version %2$s. The module files were probably rolled back without rolling back the database. Re-install a version that matches the database, or upgrade the files again.'),
                    $dbVersion,
                    $version
                )) ?>"><?= sprintf($escape($translate('⚠ DB: %s')), $escape($dbVersion)) ?></span>
                <?php endif ?>
                <?php if ($hasVersionConstraints): ?>
                    <?php if ($hasCompatibleUpdate): ?>
                    <span class="compatible-update" title="<?= $escape(sprintf($translate('Latest version compatible with Omeka S %s'), $omekaVersion)) ?>"> → <?= $escape($catalogueVersionCompatible) ?></span>
                    <?php endif ?>
                    <?php if ($catalogueVersion && $catalogueVersion !== $catalogueVersionCompatible): ?>
                    <span class="latest-version" title="<?= $escape($translate('Latest version, not compatible with this Omeka S')) ?>"> (<?= sprintf($escape($translate('latest: %s')), $escape($catalogueVersion)) ?>)</span>
                    <?php endif ?>
                    <?php if (!$catalogueVersionCompatible && $hasUpdate): ?>
                    <span class="incompatible" title="<?= $escape($translate('No compatible version available')) ?>"> → <?= $escape($catalogueVersion) ?> <?= $escape($translate('(incompatible)')) ?></span>
                    <?php endif ?>
                <?php elseif ($hasUpdate): ?>
                <span class="unknown-compat" title="<?= $escape($translate('Compatibility unknown (github/gitlab list)')) ?>"> → <?= $escape($catalogueVersion) ?></span>
                <?php endif ?>
            </td>
            <td class="col-state">
                <span><?= $escape($states[$state] ?? $state) ?></span>
                <?php if ($state === Manager::STATE_INVALID_MODULE): ?>
                <span class="error"><?= $translate('Error: invalid Module.php') ?></span>
                <?php elseif ($state === Manager::STATE_INVALID_INI): ?>
                <span class="error"><?= $translate('Error: invalid module.ini') ?></span>
                <?php elseif ($state === Manager::STATE_INVALID_OMEKA_VERSION): ?>
                <span class="error"><?= sprintf($translate('Requires Omeka S %s'), $module->getIni('omeka_version_constraint')) ?></span>
                <?php elseif ($state === Manager::STATE_NOT_FOUND): ?>
                <span class="error"><?= $translate('Not in filesystem') ?></span>
                <?php endif ?>
            </td>
        </tr>
    <?php endforeach ?>
    </tbody>
</table>

