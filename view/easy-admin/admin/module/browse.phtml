                            <button type="submit" name="state_action_id" value="activate:<?= $escape($moduleId) ?>"
                                formaction="<?= $escape($url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'activate'], ['query' => ['id' => $moduleId]])) ?>"
