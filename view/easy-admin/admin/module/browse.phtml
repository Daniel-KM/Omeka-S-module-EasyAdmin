                        </li>
                        <li>
                            <button type="submit" name="state_action_id" value="uninstall:<?= $escape($moduleId) ?>"
                                formaction="<?= $escape($url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'uninstall'], ['query' => ['id' => $moduleId]])) ?>"
                                class="o-icon-uninstall button"><?= $translate('Uninstall') ?></button>
                        </li>
                        <?php endif ?>

                        <?php if (Manager::STATE_ACTIVE === $state): ?>
