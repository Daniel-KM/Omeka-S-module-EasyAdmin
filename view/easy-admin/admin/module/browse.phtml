    <?php foreach ($installedModules as $moduleId => $module):
        $state = $module->getState();
        $errorStates = [
            Manager::STATE_NOT_FOUND,
            Manager::STATE_INVALID_MODULE,
            Manager::STATE_INVALID_INI,
            Manager::STATE_INVALID_OMEKA_VERSION,
        ];
        $isComposer = is_dir($composerAddonsPath . '/' . $moduleId);
        $ini = $module->getIni();
        $version = $ini['version'] ?? '';
        $name = $module->getName() ?: $moduleId;

        // Detect a rollback: the database is on a higher version than the
        // installed files. This usually happens when an admin reverts a
        // module after a failed update without rolling back the schema.
        $dbVersion = (string) ($module->getDb('version') ?? '');
        $versionMismatch = $version
            && $dbVersion
            && version_compare($dbVersion, $version, '>');

        $catalogueVersion = null;
        $catalogueVersionCompatible = null;
        $hasVersionConstraints = false;
        foreach ($catalogueModules as $cm) {
            if (($cm['dir'] ?? '') !== $moduleId) {
                continue;
            }
            $catalogueVersion = $cm['version'] ?? null;
            // Per-version compatibility info is only available for addons from
            // omeka.org (json). The github/gitlab CSV list only carries the
            // latest version.
            if (!empty($cm['versions'])) {
                $hasVersionConstraints = true;
                foreach ($cm['versions'] as $v => $vData) {
                    $constraint = (string) ($vData['omeka_version_constraint'] ?? '');
                    if (!mb_strlen($constraint)) {
                        $isCompatible = true;
                    } else {
                        try {
                            $isCompatible = Semver::satisfies($omekaVersion, $constraint);
                        } catch (\UnexpectedValueException $e) {
                            // Many modules don't follow semver. Fallback to
                            // version_compare-based parser; if it can't parse,
                            // assume compatible to avoid hiding updates.
                            $fallback = $checkConstraintFallback($omekaVersion, $constraint);
                            $isCompatible = $fallback === null ? true : $fallback;
                        }
                    }
                    if ($isCompatible) {
                        $catalogueVersionCompatible = $v;
                        break;
                    }
                }
            }
            break;
        }
        $hasUpdate = $catalogueVersion
            && $version
            && version_compare($version, $catalogueVersion, '<');
        $hasCompatibleUpdate = $catalogueVersionCompatible
            && $version
            && version_compare($version, $catalogueVersionCompatible, '<');

        if ($filterState === 'error' && !in_array($state, $errorStates)) {
            continue;
        } elseif ($filterState === 'update_available' && !$hasUpdate) {
            continue;
        } elseif ($filterState && !in_array($filterState, ['error', 'update_available'], true) && $state !== $filterState) {
            continue;
        }
    ?>
