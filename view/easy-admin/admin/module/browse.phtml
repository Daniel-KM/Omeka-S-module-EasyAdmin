<script>
$('.state-filter select').change(function() {
    $(this).closest('form').submit();
});

<?php if ($selections): ?>
var selections = <?= json_encode($selections, JSON_UNESCAPED_UNICODE) ?>;
$('#selection-filter').on('change', function() {
    var name = $(this).val();
    var $checks = $('.addon-checklist input[type="checkbox"]');
    $checks.prop('checked', false);
    if (name && selections[name]) {
        var dirs = selections[name].map(function(d) { return d.replace(/\s/g, ''); });
        $checks.each(function() {
            var dir = ($(this).data('addon-dir') || '').replace(/\s/g, '');
            if (dirs.indexOf(dir) !== -1) {
                $(this).prop('checked', true);
            }
        });
    }
});
<?php endif ?>
</script>
